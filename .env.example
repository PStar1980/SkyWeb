# SkyWeb local development configuration
# Copy to .env.local for local overrides when needed.
# The active SkyWeb client is apps/web-dotnet/SkyWeb.Client.

# Browser-facing API base.
# With the Vite proxy enabled, /api is recommended.
VITE_SKYWEB_API_BASE_URL=/api
VITE_SKYSERVER_API_BASE_URL=/api

# Vite dev-server proxy target for /api requests.
VITE_SKYWEB_API_ORIGIN=http://localhost:7280

# SkyServer remains available as the control-plane/evaluator origin.
VITE_SKYSERVER_API_ORIGIN=http://localhost:7171

# Public macro endpoint namespace under the active API base URL.
VITE_MACRO_API_PREFIX=/public/macro

# SkyWeb auth app-code. Login sends this to the active auth endpoint.
VITE_SKYWEB_AUTH_APP_CODE=SKYWEB

# Browser localStorage key for the SkyWeb session token.
VITE_SKYWEB_SESSION_TOKEN_KEY=skyweb.sessionToken

# Public shell remains enabled while private/member surfaces are protected by auth.
VITE_SKYWEB_PUBLIC_MODE=true

# Client request timeout.
VITE_API_TIMEOUT_MS=20000
