# SkyWeb local development configuration
# Copy to .env.local for local overrides.

# Browser-facing API base. With the Vite proxy enabled, /api is recommended.
VITE_SKYSERVER_API_BASE_URL=/api

# Vite dev-server proxy target for /api requests.
VITE_SKYSERVER_API_ORIGIN=http://localhost:7171

# Macro endpoint namespace under VITE_SKYSERVER_API_BASE_URL.
# Public macro endpoint namespace under VITE_SKYSERVER_API_BASE_URL.
VITE_MACRO_API_PREFIX=/public/macro

# Public shell mode. Future SkyWeb auth can flip this when needed.
VITE_SKYWEB_PUBLIC_MODE=true
