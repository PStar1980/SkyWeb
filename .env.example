# SkyWeb local development configuration
# Copy to .env.local for local overrides.

# Browser-facing API base. With the Vite proxy enabled, /api is recommended.
VITE_SKYSERVER_API_BASE_URL=/api

# Vite dev-server proxy target for /api requests.
VITE_SKYSERVER_API_ORIGIN=http://localhost:7171

# Public macro endpoint namespace under VITE_SKYSERVER_API_BASE_URL.
VITE_MACRO_API_PREFIX=/public/macro

# SkyWeb auth app-code. Login sends this to SkyServer's app-scoped auth endpoint.
VITE_SKYWEB_AUTH_APP_CODE=SKYWEB

# Browser localStorage key for the SkyWeb session token.
VITE_SKYWEB_SESSION_TOKEN_KEY=skyweb.sessionToken

# Public shell remains enabled while private/member surfaces are added incrementally.
VITE_SKYWEB_PUBLIC_MODE=true
# Optional .NET lane values. The copied apps/web-dotnet/SkyWeb.Client has its own .env.development.
# VITE_SKYWEB_API_BASE_URL=http://localhost:7280/api
# VITE_SKYWEB_API_ORIGIN=http://localhost:7280
