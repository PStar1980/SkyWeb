#!/bin/sh
echo "💫 Running pre-commit checks on staged files..."

# Run lint-staged and capture its output
OUTPUT=$(npx lint-staged --allow-empty 2>&1)
STATUS=$?

# Count files touched by ESLint or Prettier
FIXED=$(echo "$OUTPUT" | grep -E "eslint|prettier" | grep -Eo "[0-9]+ files" | awk '{sum+=$1} END {print sum+0}')

# Fancy visual log
if [ $STATUS -eq 0 ]; then
  echo "✨ Pre-commit complete — $FIXED file(s) formatted or fixed."
else
  echo "❌ Lint-staged failed. Review above output before committing."
  echo "$OUTPUT"
  exit 1
fi
